{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dev",
            "dependsOn": ["air", "vite"],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "air",
            "type": "shell",
            "command": "air",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "group": "dev"
            }
        },
        {
            "label": "vite",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/web/app"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "group": "dev"
            }
        },
        {
            "label": "npm build",
            "type": "shell",
            "command": "npm run build",
            "options": {
                "cwd": "${workspaceFolder}/web/app"
            },
            "problemMatcher": "$tsc",
            "presentation": {
                "reveal": "silent",
                "panel": "new"
            }
        }
    ]
}
